				rdz = ndcX*rvz + ndcY*uvz + lvz
				invLen = 1 / msqrt(rdx*rdx + rdy*rdy + rdz*rdz)
				rdx = rdx*invLen
				rdy = rdy*invLen
				rdz = rdz*invLen

