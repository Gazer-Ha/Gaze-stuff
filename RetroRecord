function fadeIn(frame, duration, startAlpha, endAlpha, callback)
	frame.BackgroundTransparency = startAlpha
	myTween = TweenService:Create(frame, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = endAlpha})
	myTween:Play()
	if callback then
		myTween.Completed:Connect(callback)
	end
end

function fadeLabel(label, duration, startAlpha, endAlpha, callback)
	label.TextTransparency = startAlpha
	myTween2 = TweenService:Create(label, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = endAlpha})
	myTween2:Play()
	if callback then
		myTween2.Completed:Connect(callback)
	end
end

