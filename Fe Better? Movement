-- [[ TILT & SHIFT-LOCK SCRIPT ]] --
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local shiftLockToggled = false
local guiParent = (type(gethui) == "function" and gethui()) or game:GetService("CoreGui")
local shiftLockGui = Instance.new("ScreenGui")
shiftLockGui.Name = "CustomShiftLockGui"
shiftLockGui.ResetOnSpawn = false
shiftLockGui.Parent = guiParent

local shiftLockButton = Instance.new("ImageButton")
shiftLockButton.Name = "ShiftLockButton"
shiftLockButton.AnchorPoint = Vector2.new(0.5, 0.5) 
shiftLockButton.Size = UDim2.new(0, 50, 0, 50)
shiftLockButton.Position = UDim2.new(0.85, 25, 0.85, 25) 
shiftLockButton.BackgroundTransparency = 1
shiftLockButton.Image = "rbxassetid://105987953182009"
shiftLockButton.Draggable = true
shiftLockButton.Active = true
shiftLockButton.Parent = shiftLockGui

local currentBasePos = shiftLockButton.Position

shiftLockButton:GetPropertyChangedSignal("Position"):Connect(function()
	if not TweenService:GetValue(0, Enum.EasingStyle.Back, Enum.EasingDirection.Out) then 
		currentBasePos = shiftLockButton.Position
	end
end)

local gradient = Instance.new("UIGradient")
gradient.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 150, 255)),
    ColorSequenceKeypoint.new(0.49, Color3.fromRGB(0, 150, 255)),
    ColorSequenceKeypoint.new(0.51, Color3.fromRGB(255, 255, 255)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
})
gradient.Offset = Vector2.new(-0.5, 0) 
gradient.Parent = shiftLockButton

local squishTime = 0.08
local squishInfo = TweenInfo.new(squishTime, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local resetInfo = TweenInfo.new(0.1, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
local gradientInfo = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

shiftLockButton.MouseButton1Click:Connect(function()
    shiftLockToggled = not shiftLockToggled
    local targetSize = UDim2.new(0, 65, 0, 35)
    local currentPos = shiftLockButton.Position
    local targetPos = UDim2.new(
        currentPos.X.Scale, 
        currentPos.X.Offset, 
        currentPos.Y.Scale, 
        currentPos.Y.Offset + 7
    )
    
    local squishTween = TweenService:Create(shiftLockButton, squishInfo, {
        Size = targetSize,
        Position = targetPos
    })
    squishTween:Play()
    
    task.delay(squishTime, function()
        TweenService:Create(shiftLockButton, resetInfo, {
            Size = UDim2.new(0, 50, 0, 50),
            Position = currentPos
        }):Play()
    end)
    
    local targetOffset = shiftLockToggled and Vector2.new(0.5, 0) or Vector2.new(-0.5, 0)
    local gradientTween = TweenService:Create(gradient, gradientInfo, {Offset = targetOffset})
    gradientTween:Play()
end)

local function isFirstPerson()
    local head = character:FindFirstChild("Head")
    if not head then return false end
    return (camera.CFrame.Position - head.Position).Magnitude < 1
end

local attachment = rootPart:FindFirstChild("RotationAttachment") or Instance.new("Attachment", rootPart)
attachment.Name = "RotationAttachment"

local align = rootPart:FindFirstChild("RotationWeld") or Instance.new("AlignOrientation", rootPart)
align.Name = "RotationWeld"
align.Mode = Enum.OrientationAlignmentMode.OneAttachment
align.Attachment0 = attachment
align.RigidityEnabled = false 
align.MaxTorque = math.huge
align.MaxAngularVelocity = math.huge
align.Responsiveness = 55 
align.Enabled = true

humanoid.AutoRotate = false

humanoid.Seated:Connect(function(isSeated)
    if isSeated then
        align.Enabled = false
        humanoid.AutoRotate = true
        humanoid.CameraOffset = Vector3.new(0, 0, 0)
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    else
        align.Enabled = true
        humanoid.AutoRotate = false
    end
end)

local maxTilt, fadeSpeed, tiltMultiplier = 40, 10, 1.2
local currentTiltX, currentTiltZ = 0, 0
local jumpTiltFactor = 1/3

RunService.RenderStepped:Connect(function(dt)
    if not character or not character.Parent or humanoid.Sit or humanoid.Health <= 0 then return end

    local isFP = isFirstPerson()
    local shiftLockActive = shiftLockToggled or isFP
    
    if shiftLockActive then
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        humanoid.CameraOffset = humanoid.CameraOffset:Lerp(isFP and Vector3.zero or Vector3.new(1.75, 0, 0), 0.2)
    else
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        humanoid.CameraOffset = humanoid.CameraOffset:Lerp(Vector3.zero, 0.2)
    end

    local moveDir = humanoid.MoveDirection
    local speed = rootPart.Velocity.Magnitude
    local state = humanoid:GetState()
    local inAir = (state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall)
    
    local flatLook = rootPart.CFrame.LookVector
    local lookTarget = CFrame.lookAt(Vector3.zero, Vector3.new(flatLook.X, 0, flatLook.Z).Unit)
    
    if shiftLockActive then
        local camLook = camera.CFrame.LookVector
        lookTarget = CFrame.lookAt(Vector3.zero, Vector3.new(camLook.X, 0, camLook.Z).Unit)
    elseif moveDir.Magnitude > 0 then
        lookTarget = CFrame.lookAt(Vector3.zero, moveDir)
    end

    local targetTiltX, targetTiltZ = 0, 0
    if speed > 0.1 then
        local look, right = rootPart.CFrame.LookVector, rootPart.CFrame.RightVector
        targetTiltX = math.clamp(-moveDir:Dot(look) * tiltMultiplier * speed, -maxTilt, maxTilt)
        targetTiltZ = math.clamp(-moveDir:Dot(right) * tiltMultiplier * speed, -maxTilt, maxTilt)
    end

    if inAir then
        targetTiltX, targetTiltZ = targetTiltX * jumpTiltFactor, targetTiltZ * jumpTiltFactor
    end

    currentTiltX += (targetTiltX - currentTiltX) * dt * fadeSpeed
    currentTiltZ += (targetTiltZ - currentTiltZ) * dt * fadeSpeed
    align.CFrame = lookTarget * CFrame.Angles(math.rad(currentTiltX), 0, math.rad(currentTiltZ))
end)



--// Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

--// Player & Constants
local player = Players.LocalPlayer

--// Animation IDs
local SIDE_ID   = "rbxassetid://132218385473651"
local BACK_ID   = "rbxassetid://16738337225"
local POSE_ID   = "rbxassetid://82261197744576"
local TRACK1_ID = "rbxassetid://138665010911335"
local TRACK2_ID = "rbxassetid://140131631438778"

local connections = {}

--// Helper: Load animation safely
local function loadAnimation(animator, id, priority, looped)
	local anim = Instance.new("Animation")
	anim.AnimationId = id
	local track = animator:LoadAnimation(anim)
	track.Priority = priority
	if looped ~= nil then track.Looped = looped end
	return track
end

--// Main character setup
local function setupCharacter(char)
	-- Cleanup old connections
	for _, c in ipairs(connections) do c:Disconnect() end
	table.clear(connections)

	local humanoid = char:WaitForChild("Humanoid")
	local animator = humanoid:WaitForChild("Animator")
	local rootPart = char:WaitForChild("HumanoidRootPart")
	
	-- Check for R6 Compatibility
	local isR6 = humanoid.RigType == Enum.HumanoidRigType.R6
	if isR6 then
		StarterGui:SetCore("SendNotification", {
			Title = "FE Better Movement",
			Text = "R6 detected. Loading external module...",
			Duration = 5
		})
		coroutine.wrap(function()
			loadstring(game:HttpGet("https://raw.githubusercontent.com/Gazer-Ha/NOT-MINE/refs/heads/main/R6%20animation%20custe"))()
		end)()
		return -- Stop R15 logic if R6
	end

	--// Load R15 tracks
	local sideTrack     = loadAnimation(animator, SIDE_ID, Enum.AnimationPriority.Movement, true)
	local backwardTrack = loadAnimation(animator, BACK_ID, Enum.AnimationPriority.Movement, true)
	local poseTrack     = loadAnimation(animator, POSE_ID, Enum.AnimationPriority.Action4, false)
	local track1        = loadAnimation(animator, TRACK1_ID, Enum.AnimationPriority.Action, true)
	local track2        = loadAnimation(animator, TRACK2_ID, Enum.AnimationPriority.Action, true)

	-- Ensure PoseTrack length is loaded
	if poseTrack.Length == 0 then
		poseTrack:GetPropertyChangedSignal("Length"):Wait()
	end

	local function playPose()
		poseTrack:Play(0)
		poseTrack.TimePosition = poseTrack.Length * 0.98
		poseTrack:AdjustSpeed(0) -- Freeze at end
	end

	playPose()

	-- Keep Pose active
	connections[#connections+1] = poseTrack.Stopped:Connect(playPose)

	--// Logic Loop
	connections[#connections+1] = RunService.RenderStepped:Connect(function(dt)
		if not char.Parent or humanoid.Health <= 0 then return end

		-- Safety check for Pose
		if not poseTrack.IsPlaying then playPose() end

		local moveDir = humanoid.MoveDirection
		local actualSpeed = Vector3.new(rootPart.AssemblyLinearVelocity.X, 0, rootPart.AssemblyLinearVelocity.Z).Magnitude
		local isMoving = moveDir.Magnitude > 0.05
		local state = humanoid:GetState()

		local inAir = state == Enum.HumanoidStateType.Jumping or 
					  state == Enum.HumanoidStateType.Freefall or 
					  state == Enum.HumanoidStateType.FallingDown or 
					  humanoid.Sit

		--// MOVEMENT LOGIC
		if isMoving and not inAir then
			poseTrack:AdjustWeight(0.05) -- Low weight during movement
			
			-- Stop Idle layers
			if track1.IsPlaying then track1:Stop(0.1) end
			if track2.IsPlaying then track2:Stop(0.1) end

			local forwardDot = moveDir:Dot(rootPart.CFrame.LookVector)
			local rightDot = moveDir:Dot(rootPart.CFrame.RightVector)

			-- Primarily Sideways
			if math.abs(rightDot) > math.abs(forwardDot) then
				if not sideTrack.IsPlaying then sideTrack:Play(0.2) end
				sideTrack:AdjustSpeed(1.5 * (actualSpeed / 15) * (rightDot >= 0 and -1 or 1))
				
				if backwardTrack.IsPlaying then backwardTrack:Stop(0.2) end

			-- Primarily Backward
			elseif forwardDot <= -0.5 then
				if not backwardTrack.IsPlaying then backwardTrack:Play(0.2) end
				backwardTrack:AdjustSpeed(-1.3 * (actualSpeed / 15))
				
				if sideTrack.IsPlaying then sideTrack:Stop(0.2) end

			-- Forward movement (Let default animations handle it)
			else
				if sideTrack.IsPlaying then sideTrack:Stop(0.2) end
				if backwardTrack.IsPlaying then backwardTrack:Stop(0.2) end
			end

		--// IDLE OR AIRBORNE LOGIC
		else
			-- Stop custom movement tracks
			if sideTrack.IsPlaying then sideTrack:Stop(0.2) end
			if backwardTrack.IsPlaying then backwardTrack:Stop(0.2) end

			if inAir then
				poseTrack:AdjustWeight(0.05)
				if track1.IsPlaying then track1:Stop(0.1) end
				if track2.IsPlaying then track2:Stop(0.1) end
			else
				-- True Idle
				poseTrack:AdjustWeight(0.08)
				
				if not track1.IsPlaying then track1:Play(0.1) end
				track1:AdjustWeight(0.9, 0.1)

				if not track2.IsPlaying then track2:Play(0.1) end
				track2:AdjustWeight(0.2, 0.1)
			end
		end
	end)
end

--// Initial Setup & Respawn Handling
if player.Character then setupCharacter(player.Character) end
