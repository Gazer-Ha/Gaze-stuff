									nlg += nl.g * atten
									nlb += nl.b * atten
								end
							end
						end
						ns = 1 / 255
						dr = dr + nlr * ns * pr * ns
						dg = dg + nlg * ns * pg * ns
						db = db + nlb * ns * pb * ns
						reflectivity = MAT_REFLECT[mat] or 0.30
						dot2 = 2 * (rdx*nnx + rdy*nny + rdz*nnz)
						refDx = rdx - dot2*nnx
						refDy = rdy - dot2*nny
						refDz = rdz - dot2*nnz
						refRes = CastRayIgnoreTransparent(offsetOrigin, Vector3.new(refDx, refDy, refDz), 300)
						rr = 0
						rg = 0
						rb = 0
