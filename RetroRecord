local function fadeIn(frame, duration, startAlpha, endAlpha, callback)
	frame.BackgroundTransparency = startAlpha
	local tween = TweenService:Create(frame, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = endAlpha})
	tween:Play()
	if callback then
		tween.Completed:Connect(callback)
	end
end

local function fadeLabel(label, duration, startAlpha, endAlpha, callback)
	label.TextTransparency = startAlpha
	local tween = TweenService:Create(label, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = endAlpha})
	tween:Play()
	if callback then
		tween.Completed:Connect(callback)
	end
end

