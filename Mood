local moods = {}

local function saveData()
    local data = {}
    for _, m in ipairs(moods) do
        table.insert(data, {id=m.id, name=m.name, custom=m.custom})
    end
    pcall(function() writefile(SAVE_FILE, HttpSvc:JSONEncode(data)) end)
end

local function loadData()
    local ok, content = pcall(function() return readfile(SAVE_FILE) end)
    if ok and content then
        local dok, decoded = pcall(function() return HttpSvc:JSONDecode(content) end)
        if dok and type(decoded) == "table" then
            for _, entry in ipairs(decoded) do
                if type(entry) == "table" and type(entry.id) == "number" then
                    table.insert(moods, {id=entry.id, name=entry.name, custom=entry.custom})
                end
            end
            return true
        end
    end
    return false
end

if not loadData() then
    for _, m in ipairs(defaultMoods) do
        table.insert(moods, {id=m.id, name=m.name, custom=false})
    end
    saveData()
end

