if getgenv().TiltConnection then
    getgenv().TiltConnection:Disconnect()
    getgenv().TiltConnection = nil
end



local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local function setup(character)
    local humanoid = character:WaitForChild("Humanoid")
    local hrp = character:WaitForChild("HumanoidRootPart")

    humanoid.AutoRotate = false

    local att = hrp:FindFirstChild("TiltAttachment") or Instance.new("Attachment")
    att.Name = "TiltAttachment"
    att.Parent = hrp

    local align = hrp:FindFirstChild("TiltAlign") or Instance.new("AlignOrientation")
    align.Name = "TiltAlign"
    align.Mode = Enum.OrientationAlignmentMode.OneAttachment
    align.Attachment0 = att
    align.RigidityEnabled = false
    align.MaxTorque = 9999999
    align.Responsiveness = 200
    align.Parent = hrp

    local predictionTime = 0.25
    local tiltSmoothness = 15
    local pitchStrength = 0.1 
    local classicPitchStrength = 0.05
    local verticalDeadzone = 0.05
    local maxTiltSide = 18
    local sideSmoothness = 15

    local currentPitch = 0
    local currentSide = 0

    local conn
    conn = RunService.RenderStepped:Connect(function(dt)
        if not character or not character.Parent or not hrp or not hrp.Parent then
            conn:Disconnect()
            return
        end

        local camera = workspace.CurrentCamera
        local moveDir = humanoid.MoveDirection
        local targetSide = 0
        local targetPitch = 0

        if moveDir.Magnitude > 0 then
            local localMove = hrp.CFrame:VectorToObjectSpace(moveDir)
            targetSide = -localMove.X * maxTiltSide
        end
        currentSide += (targetSide - currentSide) * math.min(dt * sideSmoothness, 1)

        if moveDir.Magnitude > 0 then
            local velocity = hrp.AssemblyLinearVelocity
            local predictedPos = hrp.Position + (velocity * predictionTime)
            local dy = predictedPos.Y - hrp.Position.Y

            if math.abs(dy) > verticalDeadzone then
                local flatDist = (Vector3.new(predictedPos.X, 0, predictedPos.Z) - Vector3.new(hrp.Position.X, 0, hrp.Position.Z)).Magnitude
                targetPitch = math.atan2(dy, math.max(flatDist, 0.1)) * pitchStrength
            end

            local localMove = hrp.CFrame:VectorToObjectSpace(moveDir)
            targetPitch += (localMove.Z) * classicPitchStrength
        end

        currentPitch += (targetPitch - currentPitch) * math.clamp(dt * tiltSmoothness, 0, 1)

        local isFirstPerson = (camera.CFrame.Position - camera.Focus.Position).Magnitude < 1
        local yaw

        if isFirstPerson then
            local camLook = camera.CFrame.LookVector
            yaw = math.atan2(camLook.X, camLook.Z)
        else
            if moveDir.Magnitude > 0 then
                yaw = math.atan2(moveDir.X, moveDir.Z)
            else
                local look = hrp.CFrame.LookVector
                yaw = math.atan2(look.X, look.Z)
            end
        end

        local tiltRotation = CFrame.Angles(currentPitch, 0, math.rad(currentSide))
        align.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, yaw + math.pi, 0) * tiltRotation
    end)
    
    getgenv().TiltConnection = conn
end

if player.Character then
    setup(player.Character)
end

