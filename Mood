local function addMoodButton(moodEntry)
    local id = moodEntry.id
    local btn = newInst("ImageButton", {
        Name=tostring(id),
        BackgroundColor3=Color3.fromRGB(35,35,35),
        BackgroundTransparency=0.4,
        BorderSizePixel=0,
        Image="rbxthumb://type=Asset&id="..id.."&w=420&h=420",
        ScaleType=Enum.ScaleType.Crop,
        ClipsDescendants=true,
    }, scrollFrame)
    corner(3, btn)

    local nl = newInst("TextLabel", {
        Size=UDim2.new(1,0,0,16),
        Position=UDim2.new(0,0,1,-16),
        BackgroundColor3=Color3.fromRGB(0,0,0),
        BackgroundTransparency=0.35,
        BorderSizePixel=0,
        Text=moodEntry.name or "Unnamed",
        TextColor3=Color3.fromRGB(255,255,255),
        TextSize=9,
        TextScaled=true,
        Font=Enum.Font.GothamBold,
    }, btn)

    if not moodEntry.name then
        task.spawn(function()
            local ok, res = pcall(function() return MktSvc:GetProductInfo(id) end)
            if ok and res then
                local n = res.Name
                n = n:gsub("%s*%-?%s*[Mm]ood%s*$","")
                nl.Text = n
                moodEntry.name = n
            else
                nl.Text = tostring(id):sub(-4)
                moodEntry.name = tostring(id):sub(-4)
            end
        end)
    end

    btn.MouseEnter:Connect(function() TweenSvc:Create(btn, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(55,55,55)}):Play() end)
    btn.MouseLeave:Connect(function() TweenSvc:Create(btn, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(35,35,35)}):Play() end)
    btn.MouseButton1Click:Connect(function() playMood(id) end)

    local editBtn = newInst("TextButton", {
        Size=UDim2.new(0,16,0,16),
        Position=UDim2.new(1,-18,0,2),
        BackgroundColor3=Color3.fromRGB(88,101,242),
        BackgroundTransparency=0.35,
        BorderSizePixel=0,
        Text="E",
        TextSize=9,
        Font=Enum.Font.GothamBold,
        TextColor3=Color3.fromRGB(255,255,255),
        ZIndex=5,
    }, btn)
    corner(2, editBtn)

    local delBtn = newInst("TextButton", {
        Size=UDim2.new(0,16,0,16),
        Position=UDim2.new(0,2,0,2),
        BackgroundColor3=Color3.fromRGB(200,50,50),
        BackgroundTransparency=0.35,
        BorderSizePixel=0,
        Text="X",
        TextSize=9,
        Font=Enum.Font.GothamBold,
        TextColor3=Color3.fromRGB(255,255,255),
        ZIndex=5,
    }, btn)
    corner(2, delBtn)

    delBtn.MouseButton1Click:Connect(function()
        local cd, cov = makeDialog(240, 110, "Delete Mood?")
        newInst("TextLabel", {Size=UDim2.new(1,-20,0,28), Position=UDim2.new(0,10,0,32), BackgroundTransparency=1, Text="This will remove the mood permanently.", TextWrapped=true, TextColor3=Color3.fromRGB(200,200,200), TextSize=11, Font=Enum.Font.Gotham, ZIndex=152}, cd)
        local yesB = newInst("TextButton", {Size=UDim2.new(0.45,0,0,28), Position=UDim2.new(0.05,0,1,-36), BackgroundColor3=Color3.fromRGB(200,50,50), BorderSizePixel=0, Text="Delete", TextColor3=Color3.fromRGB(255,255,255), TextSize=12, Font=Enum.Font.GothamBold, ZIndex=152}, cd)
        corner(3, yesB)
        local noB = newInst("TextButton", {Size=UDim2.new(0.45,0,0,28), Position=UDim2.new(0.5,0,1,-36), BackgroundColor3=Color3.fromRGB(60,60,60), BorderSizePixel=0, Text="Cancel", TextColor3=Color3.fromRGB(255,255,255), TextSize=12, Font=Enum.Font.GothamBold, ZIndex=152}, cd)
        corner(3, noB)
        yesB.MouseButton1Click:Connect(function()
            for i, m in ipairs(moods) do
                if m.id == id then table.remove(moods, i) break end
            end
            for i, b in ipairs(moodBtns) do
                if b == btn then table.remove(moodBtns, i) break end
            end
            btn:Destroy()
            saveData()
            updateCanvas()
            cd:Destroy(); cov:Destroy()
        end)
        noB.MouseButton1Click:Connect(function() cd:Destroy(); cov:Destroy() end)
    end)

    editBtn.MouseButton1Click:Connect(function()
        showEditDialog(moodEntry, nl)
    end)

    table.insert(moodBtns, btn)
    updateCanvas()
    return btn
end

