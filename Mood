-- File persistence for saved emotes
local SAVE_FILE = "FeMoodAnimations_SavedEmotes.json"

local function saveEmotes()
    local success, err = pcall(function()
        writefile(SAVE_FILE, HttpService:JSONEncode(moodIds))
    end)
    if not success then
        warn("Failed to save emotes: " .. tostring(err))
    end
end

local function loadEmotes()
    local success, content = pcall(function()
        return readfile(SAVE_FILE)
    end)
    
    if success and content then
        local decodeSuccess, decoded = pcall(function()
            return HttpService:JSONDecode(content)
        end)
        
        if decodeSuccess and typeof(decoded) == "table" then
            -- Add loaded emotes that aren't already in the list
            for _, id in ipairs(decoded) do
                if typeof(id) == "number" then
                    local exists = false
                    for _, existingId in ipairs(moodIds) do
                        if existingId == id then
                            exists = true
                            break
                        end
                    end
                    if not exists then
                        table.insert(moodIds, id)
                    end
                end
            end
        end
    end
end

