local function createSlider(lbl, def, mn, mx, yp, cb)
    local con = newInst("Frame", {Size=UDim2.new(1,0,0,62), Position=UDim2.new(0,0,0,yp), BackgroundTransparency=1}, sSc)
    newInst("TextLabel", {Size=UDim2.new(1,0,0,14), BackgroundTransparency=1, Text=lbl, TextColor3=Color3.fromRGB(170,170,170), TextSize=10, Font=Enum.Font.GothamSemibold, TextXAlignment=Enum.TextXAlignment.Left}, con)

    local bg = newInst("TextButton", {Size=UDim2.new(1,-8,0,14), Position=UDim2.new(0,4,0,16), BackgroundColor3=Color3.fromRGB(45,45,45), BackgroundTransparency=0.35, BorderSizePixel=0, Text="", AutoButtonColor=false}, con)
    corner(3, bg)
    local fill = newInst("Frame", {Size=UDim2.new((def-mn)/(mx-mn),0,1,0), BackgroundColor3=Color3.fromRGB(88,101,242), BorderSizePixel=0}, bg)
    corner(3, fill)

    local handle = newInst("Frame", {
        Size=UDim2.new(0,10,0,20),
        Position=UDim2.new((def-mn)/(mx-mn),0-5,0.5,-10),
        BackgroundColor3=Color3.fromRGB(220,220,220),
        BackgroundTransparency=0.15,
        BorderSizePixel=0,
        ZIndex=3,
    }, bg)
    corner(2, handle)

    local tb = newInst("TextBox", {Size=UDim2.new(0,52,0,18), Position=UDim2.new(0.5,-26,0,33), BackgroundColor3=Color3.fromRGB(38,38,38), BackgroundTransparency=0.4, BorderSizePixel=0, Text=tostring(def), TextColor3=Color3.fromRGB(255,255,255), TextSize=10, Font=Enum.Font.Gotham, ClearTextOnFocus=false}, con)
    corner(2, tb)

    local dragging = false
    local function updVis(v)
        local scale = math.clamp((v-mn)/(mx-mn),0,1)
        fill.Size = UDim2.new(scale,0,1,0)
        handle.Position = UDim2.new(scale,-5,0.5,-10)
        tb.Text = string.format("%.2f", v)
    end
    local function setValue(v)
        updVis(v)
        cb(v)
    end
    local function fromInput(inp)
        local rx = math.clamp((inp.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local v = math.floor((mn + rx*(mx-mn))*100)/100
        updVis(v)
        cb(v)
    end
    bg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true; fromInput(i)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            fromInput(i)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    tb.FocusLost:Connect(function()
        local n = tonumber(tb.Text)
        if n then
            if lbl == "Weight" then
                n = math.max(0.01, n)
            else
                n = math.clamp(n, mn, mx)
            end
            n = math.floor(n*100)/100
            updVis(n)
            cb(n)
        else
            tb.Text = string.format("%.2f", cfg[string.lower(lbl)])
        end
    end)
    return {set=setValue}
end

