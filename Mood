local function applyToTrack(t)
    t.Priority = cfg.priority
    t.Looped = looped
    t:AdjustWeight(cfg.weight)
    t:AdjustSpeed(cfg.speed)
end

local function playMood(moodId)
    if curTrack then
        resetFace(char)
        curTrack:AdjustWeight(0)
        
        curTrack:Destroy()
        resetFace(char)
        curTrack = nil
    end
    curMoodId = moodId
    local animId = getAnimId(moodId)
    local a = Instance.new("Animation")
    a.AnimationId = animId
    local t = anim:LoadAnimation(a)
    applyToTrack(t)
    curTrack = t
    t:Play()
    if not looped then
        t.Stopped:Connect(function()
            if curTrack == t and curMoodId == moodId then
                t:Play()
            end
        end)
    end
end

local function updateCanvas()
