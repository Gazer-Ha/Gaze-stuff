local function applySettingsToTrack(track)
    track.Priority = settings.priority
    track.Looped = looped
    track:AdjustWeight(settings.weight)
    track:AdjustSpeed(settings.speed)
    
    if track.Length > 0 then
        track.TimePosition = settings.timePosition * track.Length
    else
        task.delay(0.1, function()
            if track and track.Parent and track.Length > 0 then
                track.TimePosition = settings.timePosition * track.Length
            end
        end)
    end
end

local function playMoodAnimation(moodId)
    if currentTrack then
        currentTrack:Stop(0.1)
        currentTrack:Destroy()
        currentTrack = nil
    end
    
    currentAnimData = moodId
    
    local animId = getAnimationIdFromMood(moodId)
    local animation = Instance.new("Animation")
    animation.AnimationId = animId
    
    local track = animator:LoadAnimation(animation)
    applySettingsToTrack(track)
    
    currentTrack = track
    track:Play()
    
    if not looped then
        track.Stopped:Connect(function()
            if currentTrack == track and currentAnimData == moodId then
                if track.Length > 0 then
                    track.TimePosition = settings.timePosition * track.Length
                end
                track:Play()
            end
        end)
    end
end

