local function getAnimId(id)
    local ok, obj = pcall(function()
        return game:GetObjects("rbxassetid://" .. math.floor(id))
    end)
    if ok and #obj > 0 then
        local r = obj[1]
        if r:IsA("Animation") and r.AnimationId ~= "" then return r.AnimationId end
        for _, d in ipairs(r:GetDescendants()) do
            if d:IsA("Animation") and d.AnimationId ~= "" then return d.AnimationId end
        end
    end
    return "rbxassetid://" .. tostring(id)
end

