	local function getCloudDensity(cx, cz, timeOffset)
		local nx = cx * CLOUD_SCALE + timeOffset * CLOUD_SPEED
		local nz = cz * CLOUD_SCALE
		local n1 = mnoise(nx, nz, timeOffset * CLOUD_SPEED * 0.05) * 0.5 + 0.5
		local n2 = mnoise(nx * 2.5, nz * 2.5, 10) * 0.5 + 0.5
		local v = n1 * 0.7 + n2 * 0.3
		if v < CLOUD_COVERAGE then return 0 end
		return mclamp((v - CLOUD_COVERAGE) * INV_CLOUD_RANGE, 0, 1) * CLOUD_OPACITY
	end

	local function getSkyRGB(opx, opy, opz, dx, dy, dz, t)
		local sun = mmax(0, dx*LDX + dy*LDY + dz*LDZ)
		local r, g, b
		if sun > 0.995 then
			r, g, b = SUNX, SUNY, SUNZ
		else
			local tv = 0.5 * (dy + 1)
			local mt = 1 - tv
			r = STPX*tv + SBTX*mt
			g = STPY*tv + SBTY*mt
			b = STPZ*tv + SBTZ*mt
			if sun > 0.98 then
				local sf = (sun - 0.98) / 0.015
				r = r + (SUNX - r) * sf
				g = g + (SUNY - g) * sf
				b = b + (SUNZ - b) * sf
			end
		end
		if dy > 0 then
			local dist = (CLOUD_HEIGHT - opy) / dy
			if dist > 0 then
				local density = getCloudDensity(opx + dx*dist, opz + dz*dist, t)
				if density > 0 then
					local f = 1 - sun
					r = r + (CCX + (180 - CCX)*f - r) * density
					g = g + (CCY + (180 - CCY)*f - g) * density
					b = b + (CCZ + (190 - CCZ)*f - b) * density
				end
			end
		end
		if LDY > 0 and sun > 0.65 then
			local proximity = (sun - 0.65) / 0.35
			local shaftNoise = mnoise(dx * 7 + t * 0.04, dy * 7, dz * 5) * 0.5 + 0.5
			local phase = (1 + sun * sun) * 0.75
			local strength = proximity * mmax(0, shaftNoise - 0.3) * phase * GOD_RAY_SKY_SHAFTS
			r = r + SUNX * strength
			g = g + SUNY * strength
			b = b + SUNZ * strength
		end
		return r, g, b
	end

	local neonBuf = table.create(MAX_NEON_LIGHTS * 2)

	local function getNearbyNeon(hpx, hpy, hpz)
		local count = 0
		for _, nl in ipairs(neonLights) do
			local dx = nl.px - hpx
			local dy = nl.py - hpy
			local dz = nl.pz - hpz
			local dsq = dx*dx + dy*dy + dz*dz
			if dsq < nl.rangeSq then
				count += 1
				neonBuf[count] = { nl = nl, dsq = dsq }
				if count >= MAX_NEON_LIGHTS * 2 then break end
			end
		end
		table.sort(neonBuf, function(a, b) return a.dsq < b.dsq end)
		local out = {}
		for i = 1, mmin(count, MAX_NEON_LIGHTS) do out[i] = neonBuf[i] end
		return out
	end

	local function CastRayIgnoreTransparent(origin, dirUnit, maxDist)
		local curOrigin = origin
		local distLeft = maxDist
		local attempts = 0
		while attempts < 4 do
			local result = Workspace:Raycast(curOrigin, dirUnit * distLeft, params)
			if result then
				local inst = result.Instance
				if inst.Transparency > 0.95 or inst.Name == "HumanoidRootPart" then
					local traveled = (result.Position - curOrigin).Magnitude
					distLeft -= traveled
					if distLeft <= 0 then return nil end
					curOrigin = result.Position + (dirUnit * 0.01)
					attempts += 1
				else
					return result
				end
			else
				return nil
			end
		end
		return nil
	end

	local function getVolumetricGodRay(opx, opy, opz, rdx, rdy, rdz, hitDist)
		local cosTheta = rdx*LDX + rdy*LDY + rdz*LDZ
		local phase = 1 + mmax(0, cosTheta) * 0.6
		local litSamples = 0
		local inv = 1 / GOD_RAY_STEPS
		for i = 1, GOD_RAY_STEPS do
			local frac = (i - 0.5) * inv
			local sx = opx + rdx * frac * hitDist
			local sy = opy + rdy * frac * hitDist
			local sz = opz + rdz * frac * hitDist
			if not CastRayIgnoreTransparent(Vector3.new(sx, sy, sz), LIGHT_DIR, 100) then
				litSamples += 1 - frac * 0.5
			end
		end
		local strength = (litSamples * inv) * GOD_RAY_SCATTER * phase
		return SUNX * strength, SUNY * strength, SUNZ * strength
	end

