								rr = rc.R*255*rlit
								rg = rc.G*255*rlit
								rb = rc.B*255*rlit
							end
						else
							rr, rg, rb = getSkyRGB(ox, oy, oz, refDx, refDy, refDz, t)
						end
						inv_ref = 1 - reflectivity
						cr = dr*inv_ref + rr*reflectivity
						cg = dg*inv_ref + rg*reflectivity
						cb = db*inv_ref + rb*reflectivity
						if LDY > 0 then
