local function updateCanvasSize()
    local visibleCount = 0
    for _, btn in ipairs(moodButtons) do
        if btn.Visible then
            visibleCount = visibleCount + 1
        end
    end
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, math.ceil(visibleCount / 3) * 85)
end

local function filterMoods(searchText)
    searchText = string.lower(searchText)
    for i, btn in ipairs(moodButtons) do
        local moodName = moodNames[i] or ""
        if searchText == "" or string.find(string.lower(moodName), searchText) then
            btn.Visible = true
        else
            btn.Visible = false
        end
    end
    updateCanvasSize()
end

