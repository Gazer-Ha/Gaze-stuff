								local srcX = px - shift
								if srcX >= 0 and srcX < RES_X then
									local srcOff = (py * RES_X + srcX) * 4
									local r = breadu8(frameBuffer, srcOff)
									local g = breadu8(frameBuffer, srcOff + 1)
									local b = breadu8(frameBuffer, srcOff + 2)
									if bright then
										r = math.min(255, r + 40)
										g = math.min(255, g + 40)
										b = math.min(255, b + 40)
									end
									if ch == 1 then r = math.min(255, r + 80)
									elseif ch == 2 then g = math.min(255, g + 70)
									else b = math.min(255, b + 90) end
									ovPx(px, py, r, g, b, 210)
								end
							end
						end
						local caShift = math.random(1, math.max(1, mfloor(RES_X * 0.03)))
						local caY = glitchBands[1].y
						local caH = glitchBands[1].h
						for py = caY, math.min(caY + caH - 1, RES_Y - 1) do
							for px = 0, RES_X - 1 do
								local srcR = math.min(px + caShift, RES_X - 1)
								local srcB = math.max(px - caShift, 0)
								local offR = (py * RES_X + srcR) * 4
								local offB = (py * RES_X + srcB) * 4
								local rr = breadu8(frameBuffer, offR)
								local gg = breadu8(frameBuffer, (py * RES_X + px) * 4 + 1)
								local bb = breadu8(frameBuffer, offB + 2)
								ovPx(px, py, rr, gg, bb, 180)
							end
						end
					end
				else
					glitchActive = false
					glitchBands = {}
				end
			end

			overlayImage:WritePixelsBuffer(Vector2.new(0, 0), Vector2.new(RES_X, RES_Y), overlayBuf)
			RunService.RenderStepped:Wait()
		end
	end)

	task.delay(2.0, function()
		TweenService:Create(pbFrame, TweenInfo.new(1.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1}):Play()
		task.delay(1.5, function()
			persistentBlack:Destroy()
		end)
	end)
end

