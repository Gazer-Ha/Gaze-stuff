	function ovPx(x, y, r, g, b, a)
		if x < 0 or x >= RES_X or y < 0 or y >= RES_Y then return end
		off = (y * RES_X + x) * 4
		buffer.writeu8(overlayBuf, off,     r)
		buffer.writeu8(overlayBuf, off + 1, g)
		buffer.writeu8(overlayBuf, off + 2, b)
		buffer.writeu8(overlayBuf, off + 3, a or 255)
	end

	function drawChar(ch, ox, oy, r, g, b, sc)
		rows = PIXEL_FONT[ch]
		if not rows then return end
		for row = 1, FONT_H do
			bits = rows[row]
			for col = 0, FONT_W - 1 do
				bit = mfloor(bits / (2 ^ (FONT_W - 1 - col))) % 2
				if bit == 1 then
					for sy = 0, sc - 1 do
						for sx = 0, sc - 1 do
							ovPx(ox + col * sc + sx, oy + (row - 1) * sc + sy, r, g, b, 255)
						end
					end
				end
			end
		end
	end

	function drawString(str, ox, oy, r, g, b, sc)
		cx = ox
		for i = 1, #str do
