function launchMainScript()
	RunService = game:GetService("RunService")
	UserInputService = game:GetService("UserInputService")
	AssetService = game:GetService("AssetService")
	Workspace = game:GetService("Workspace")

	camera = workspace.CurrentCamera

	player.CameraMode = Enum.CameraMode.LockFirstPerson
	camera.FieldOfView = 120

	BOB_SPEED = 14
	BOB_SENS = 0.25
	SWAY_SENS = 0.3
	MOUSE_TILT_SENS = 0.6
	SMOOTHNESS = 0.15
	bobTime = 0
	currentIntensity = 0
	lastPos = Vector3.new()
	lastTilt = 0

	RunService:BindToRenderStep("CleanFPSCamera", Enum.RenderPriority.Camera.Value + 1, function(dt)
		char = player.Character
		hum = char and char:FindFirstChild("Humanoid")
		root = char and char:FindFirstChild("HumanoidRootPart")
		if not hum or not root or hum.Health <= 0 then return end
		velocity = root.AssemblyLinearVelocity
		speed = Vector3.new(velocity.X, 0, velocity.Z).Magnitude
		moving = speed > 1 and hum.MoveDirection.Magnitude > 0
		targetIntensity = moving and math.clamp(speed / 16, 0, 1.2) or 0
		currentIntensity = math.lerp(currentIntensity, targetIntensity, 0.1)
		bobTime = bobTime + (dt * BOB_SPEED)
		vBob = math.abs(math.sin(bobTime)) * BOB_SENS * currentIntensity
		hSway = math.sin(bobTime * 0.5) * SWAY_SENS * currentIntensity
		tSway = math.sin(bobTime * 0.5) * (currentIntensity * 1.5)
		mouseDelta = UserInputService:GetMouseDelta()
		mouseRoll = 0
		if math.abs(mouseDelta.X) > 0.1 then
			mouseRoll = math.clamp(-mouseDelta.X * MOUSE_TILT_SENS, -8, 8)
		end
		targetPos = Vector3.new(hSway, vBob, 0)
		targetTilt = math.rad(mouseRoll + tSway)
		lastPos = lastPos:Lerp(targetPos, SMOOTHNESS)
		lastTilt = math.lerp(lastTilt, targetTilt, SMOOTHNESS)
		camera.CFrame = camera.CFrame
			* CFrame.new(lastPos.X, lastPos.Y, 0)
			* CFrame.Angles(0, 0, lastTilt)
	end)

	player.CharacterAdded:Connect(function(char)
		head = char:WaitForChild("Head")
		head.LocalTransparencyModifier = 1
		head:GetPropertyChangedSignal("LocalTransparencyModifier"):Connect(function()
			head.LocalTransparencyModifier = 1
		end)
	end)

	DOWNSCALE = 5
	MIN_DIM = math.min(camera.ViewportSize.X, camera.ViewportSize.Y) / DOWNSCALE
	RES_X = math.floor(MIN_DIM)
	RES_Y = math.floor(MIN_DIM)
	TOTAL_PIXELS = RES_X * RES_Y
	BATCH_SIZE = math.floor(TOTAL_PIXELS * 0.15)
	LIGHT_DIR = Vector3.new(0.5, 0.8, 0.5).Unit
	SUN_COLOR = Vector3.new(255, 250, 240)
