-- [[ SCRIPT 2: ANIMATIONS ]]
----------------------------------------------------------------------
task.spawn(function()
    local SIDE_ID, BACK_ID, POSE_ID = "rbxassetid://132218385473651", "rbxassetid://16738337225", "rbxassetid://82261197744576"
    local TRACK1_ID, TRACK2_ID = "rbxassetid://138665010911335", "rbxassetid://140131631438778"

    local function setupCharacter(char)
        local humanoid = char:WaitForChild("Humanoid")
        local animator = humanoid:WaitForChild("Animator")
        local rootPart = char:WaitForChild("HumanoidRootPart")
        
        if humanoid.RigType == Enum.HumanoidRigType.R6 then
            coroutine.wrap(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/Gazer-Ha/NOT-MINE/refs/heads/main/R6%20animation%20custe"))() end)()
            return 
        end

        local function loadAnim(id, prio)
            local a = Instance.new("Animation") a.AnimationId = id
            local t = animator:LoadAnimation(a) t.Priority = prio t.Looped = true return t
        end

        local sideTrack = loadAnim(SIDE_ID, Enum.AnimationPriority.Movement)
        local backTrack = loadAnim(BACK_ID, Enum.AnimationPriority.Movement)
        local poseTrack = loadAnim(POSE_ID, Enum.AnimationPriority.Action4)
        local track1 = loadAnim(TRACK1_ID, Enum.AnimationPriority.Action)
        local track2 = loadAnim(TRACK2_ID, Enum.AnimationPriority.Action)

        -- Safely wait for length and play once (Removed the freeze so it can replay later)
        task.spawn(function() 
            while poseTrack.Length <= 0 do
                task.wait()
            end
            poseTrack:Play(0,1,0)
            poseTrack:AdjustSpeed(0)
            poseTrack.TimePosition = poseTrack.Length * 0.98
        end)

        local wasMoving = false -- Track whether the player was moving in the previous frame
        local animConn

        animConn = RunService.RenderStepped:Connect(function()
            if not char.Parent or humanoid.Health <= 0 then animConn:Disconnect() return end

            local moveDir = humanoid.MoveDirection
            local speed = rootPart.AssemblyLinearVelocity.Magnitude
            local inAir = humanoid:GetState() == Enum.HumanoidStateType.Jumping or humanoid:GetState() == Enum.HumanoidStateType.Freefall or humanoid.Sit

            if moveDir.Magnitude > 0.05 and not inAir then
                wasMoving = true -- Update state: Character is moving

                poseTrack:AdjustWeight(0.09) 
                track1:Stop(0.1) track2:Stop(0.1)
                
                local fwd = moveDir:Dot(rootPart.CFrame.LookVector)
                local side = moveDir:Dot(rootPart.CFrame.RightVector)

                if math.abs(side) > math.abs(fwd) then
                    if not sideTrack.IsPlaying then sideTrack:Play(0.2) end
                    sideTrack:AdjustSpeed(1.5 * (speed/15) * (side >= 0 and -1 or 1))
                    backTrack:Stop(0.2)
                elseif fwd <= -0.5 then
                    if not backTrack.IsPlaying then backTrack:Play(0.2) end
                    backTrack:AdjustSpeed(-1.3 * (speed/15))
                    sideTrack:Stop(0.2)
                else
                    sideTrack:Stop(0.2) backTrack:Stop(0.2)
                end
            else
                sideTrack:Stop(0.2) backTrack:Stop(0.2)
                if inAir then
                    wasMoving = false
                    poseTrack:AdjustWeight(0.06) 
                    track1:Stop(0.1) track2:Stop(0.1)
                else
                    -- Stopped / Idling State
                    if wasMoving then
                        -- The character JUST stopped moving. Replay the pose track.
                        
                        poseTrack:AdjustSpeed(0)
                        if not poseTrack.IsPlaying then 
                            poseTrack:Play(0,1,0)
                            poseTrack.TimePosition = poseTrack.Length * 0.98
                        end
                        wasMoving = false
                    end

                    poseTrack:AdjustWeight(0.09) 
                    if not track1.IsPlaying then track1:Play(0.1) end
                    if not track2.IsPlaying then track2:Play(0.1) end
                    track1:AdjustWeight(0.9, 0.1) track2:AdjustWeight(0.2, 0.1)
                end
            end
        end)
    end

    player.CharacterAdded:Connect(setupCharacter)
    if player.Character then setupCharacter(player.Character) end
end)
