local function launchMainScript()
	local RunService = game:GetService("RunService")
	local UserInputService = game:GetService("UserInputService")
	local AssetService = game:GetService("AssetService")
	local Workspace = game:GetService("Workspace")

	local camera = workspace.CurrentCamera

	player.CameraMode = Enum.CameraMode.LockFirstPerson
	camera.FieldOfView = 120

	local BOB_SPEED = 14
	local BOB_SENS = 0.25
	local SWAY_SENS = 0.3
	local MOUSE_TILT_SENS = 0.6
	local SMOOTHNESS = 0.15
	local bobTime = 0
	local currentIntensity = 0
	local lastPos = Vector3.new()
	local lastTilt = 0

	RunService:BindToRenderStep("CleanFPSCamera", Enum.RenderPriority.Camera.Value + 1, function(dt)
		local char = player.Character
		local hum = char and char:FindFirstChild("Humanoid")
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if not hum or not root or hum.Health <= 0 then return end
		local velocity = root.AssemblyLinearVelocity
		local speed = Vector3.new(velocity.X, 0, velocity.Z).Magnitude
		local moving = speed > 1 and hum.MoveDirection.Magnitude > 0
		local targetIntensity = moving and math.clamp(speed / 16, 0, 1.2) or 0
		currentIntensity = math.lerp(currentIntensity, targetIntensity, 0.1)
		bobTime = bobTime + (dt * BOB_SPEED)
		local vBob = math.abs(math.sin(bobTime)) * BOB_SENS * currentIntensity
		local hSway = math.sin(bobTime * 0.5) * SWAY_SENS * currentIntensity
		local tSway = math.sin(bobTime * 0.5) * (currentIntensity * 1.5)
		local mouseDelta = UserInputService:GetMouseDelta()
		local mouseRoll = 0
		if math.abs(mouseDelta.X) > 0.1 then
			mouseRoll = math.clamp(-mouseDelta.X * MOUSE_TILT_SENS, -8, 8)
		end
		local targetPos = Vector3.new(hSway, vBob, 0)
		local targetTilt = math.rad(mouseRoll + tSway)
		lastPos = lastPos:Lerp(targetPos, SMOOTHNESS)
		lastTilt = math.lerp(lastTilt, targetTilt, SMOOTHNESS)
		camera.CFrame = camera.CFrame
			* CFrame.new(lastPos.X, lastPos.Y, 0)
			* CFrame.Angles(0, 0, lastTilt)
	end)

	player.CharacterAdded:Connect(function(char)
		local head = char:WaitForChild("Head")
		head.LocalTransparencyModifier = 1
		head:GetPropertyChangedSignal("LocalTransparencyModifier"):Connect(function()
			head.LocalTransparencyModifier = 1
		end)
	end)

	local DOWNSCALE = 5
	local MIN_DIM = math.min(camera.ViewportSize.X, camera.ViewportSize.Y) / DOWNSCALE
	local RES_X, RES_Y = math.floor(MIN_DIM), math.floor(MIN_DIM)
	local TOTAL_PIXELS = RES_X * RES_Y
