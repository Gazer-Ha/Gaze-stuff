--// Shared Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer

----------------------------------------------------------------------
-- [[ SCRIPT 1: TILT & SHIFT-LOCK ]]
----------------------------------------------------------------------
task.spawn(function()
    -- This function handles the Shift Lock and Tilt logic
    local function initializeTilt(character)
        local camera = workspace.CurrentCamera
        local humanoid = character:WaitForChild("Humanoid")
        local rootPart = character:WaitForChild("HumanoidRootPart")

        -- Shift Lock GUI Logic (Only Create Once)
        local guiParent = (type(gethui) == "function" and gethui()) or game:GetService("CoreGui")
        if not guiParent:FindFirstChild("CustomShiftLockGui") then
            local shiftLockGui = Instance.new("ScreenGui")
            shiftLockGui.Name = "CustomShiftLockGui"
            shiftLockGui.ResetOnSpawn = false
            shiftLockGui.Parent = guiParent

            local shiftLockButton = Instance.new("ImageButton")
            shiftLockButton.Name = "ShiftLockButton"
            shiftLockButton.AnchorPoint = Vector2.new(0.5, 0.5) 
            shiftLockButton.Size = UDim2.new(0, 50, 0, 50)
            shiftLockButton.Position = UDim2.new(0.85, 25, 0.85, 25) 
            shiftLockButton.BackgroundTransparency = 1
            shiftLockButton.Image = "rbxassetid://105987953182009"
            shiftLockButton.Draggable = true
            shiftLockButton.Active = true
            shiftLockButton.Parent = shiftLockGui

            local gradient = Instance.new("UIGradient")
            gradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 150, 255)),
                ColorSequenceKeypoint.new(0.49, Color3.fromRGB(0, 150, 255)),
                ColorSequenceKeypoint.new(0.51, Color3.fromRGB(255, 255, 255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
            })
            gradient.Offset = Vector2.new(-0.5, 0) 
            gradient.Parent = shiftLockButton

            _G.ShiftLockToggled = false

            shiftLockButton.MouseButton1Click:Connect(function()
                _G.ShiftLockToggled = not _G.ShiftLockToggled
                local targetOffset = _G.ShiftLockToggled and Vector2.new(0.5, 0) or Vector2.new(-0.5, 0)
                TweenService:Create(gradient, TweenInfo.new(0.1), {Offset = targetOffset}):Play()
            end)
        end

        local function isFirstPerson()
            local head = character:FindFirstChild("Head")
            return head and (camera.CFrame.Position - head.Position).Magnitude < 1
        end

        local attachment = rootPart:FindFirstChild("RotationAttachment") or Instance.new("Attachment", rootPart)
        attachment.Name = "RotationAttachment"

        local align = rootPart:FindFirstChild("RotationWeld") or Instance.new("AlignOrientation", rootPart)
        align.Name = "RotationWeld"
        align.Mode = Enum.OrientationAlignmentMode.OneAttachment
        align.Attachment0 = attachment
        align.MaxTorque = math.huge
        align.MaxAngularVelocity = math.huge
        align.Responsiveness = 55 
        align.Enabled = true

        humanoid.AutoRotate = false

        local maxTilt, fadeSpeed, tiltMultiplier = 40, 10, 1.2
        local currentTiltX, currentTiltZ = 0, 0
        local jumpTiltFactor = 1/3

        local conn
        conn = RunService.RenderStepped:Connect(function(dt)
            if not character.Parent or humanoid.Health <= 0 then conn:Disconnect() return end
            
            local shiftLockActive = _G.ShiftLockToggled or isFirstPerson()
            
            if shiftLockActive then
                UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
                humanoid.CameraOffset = humanoid.CameraOffset:Lerp(isFirstPerson() and Vector3.zero or Vector3.new(1.75, 0, 0), 0.2)
            else
                UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                humanoid.CameraOffset = humanoid.CameraOffset:Lerp(Vector3.zero, 0.2)
            end

            local moveDir = humanoid.MoveDirection
            local speed = rootPart.Velocity.Magnitude
            local state = humanoid:GetState()
            local inAir = (state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall)
            
            local lookTarget = CFrame.lookAt(Vector3.zero, Vector3.new(rootPart.CFrame.LookVector.X, 0, rootPart.CFrame.LookVector.Z).Unit)
            
            if shiftLockActive then
                lookTarget = CFrame.lookAt(Vector3.zero, Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z).Unit)
            elseif moveDir.Magnitude > 0 then
                lookTarget = CFrame.lookAt(Vector3.zero, moveDir)
            end

            local targetTiltX, targetTiltZ = 0, 0
            if speed > 0.1 then
                targetTiltX = math.clamp(-moveDir:Dot(rootPart.CFrame.LookVector) * tiltMultiplier * speed, -maxTilt, maxTilt)
                targetTiltZ = math.clamp(-moveDir:Dot(rootPart.CFrame.RightVector) * tiltMultiplier * speed, -maxTilt, maxTilt)
            end

            if inAir then targetTiltX *= jumpTiltFactor targetTiltZ *= jumpTiltFactor end

            currentTiltX += (targetTiltX - currentTiltX) * dt * fadeSpeed
            currentTiltZ += (targetTiltZ - currentTiltZ) * dt * fadeSpeed
            align.CFrame = lookTarget * CFrame.Angles(math.rad(currentTiltX), 0, math.rad(currentTiltZ))
        end)
    end

    player.CharacterAdded:Connect(initializeTilt)
    if player.Character then initializeTilt(player.Character) end
end)

