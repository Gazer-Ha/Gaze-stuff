								if density > 0.1 then
									shadowMult = mmax(AMBIENT, 1 - density * 0.8)
								end
							end
						end
						diffuse = mmax(AMBIENT, nnx*LDX + nny*LDY + nnz*LDZ) * shadowMult
						dr = pr * diffuse
						dg = pg * diffuse
						db = pb * diffuse
						nlr = 0
						nlg = 0
						nlb = 0
						nearNeon = getNearbyNeon(hpx, hpy, hpz)
						for _, entry in ipairs(nearNeon) do
							nl = entry.nl
							lx = nl.px - hpx
							ly = nl.py - hpy
							lz = nl.pz - hpz
							dist = msqrt(entry.dsq)
							invD = 1 / dist
							lnx = lx*invD
							lny = ly*invD
							lnz = lz*invD
