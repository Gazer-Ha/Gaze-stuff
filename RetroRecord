						end
					end
				else
					cr, cg, cb = getSkyRGB(cpx, cpy, cpz, rdx, rdy, rdz, t)
				end

				off = currentIdx * 4
				nr = mclamp(mfloor(cr), 0, 255)
				ng = mclamp(mfloor(cg), 0, 255)
				nb = mclamp(mfloor(cb), 0, 255)
