	function refreshNeonLights()
		list = {}
		count = 0
		for _, v in ipairs(Workspace:GetDescendants()) do
			if v:IsA("BasePart") and v.Material == Enum.Material.Neon then
				count += 1
				c = v.Color
				list[count] = {
					px = v.Position.X, py = v.Position.Y, pz = v.Position.Z,
					r = c.R * 255, g = c.G * 255, b = c.B * 255,
					rangeSq = NEON_RANGE_SQ,
				}
			elseif (v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight")) and v.Enabled then
				parent = v.Parent
				if parent and parent:IsA("BasePart") then
					count += 1
					c = v.Color
					bright = v.Brightness
					range = (v.Range > 0) and v.Range or 60
					list[count] = {
						px = parent.Position.X, py = parent.Position.Y, pz = parent.Position.Z,
						r = c.R * 255 * bright * 2,
						g = c.G * 255 * bright * 2,
						b = c.B * 255 * bright * 2,
						rangeSq = range * range,
					}
				end
			end
		end
		neonLights = list
	end

	function getCloudDensity(cx, cz, timeOffset)
		nx = cx * CLOUD_SCALE + timeOffset * CLOUD_SPEED
		nz = cz * CLOUD_SCALE
		n1 = mnoise(nx, nz, timeOffset * CLOUD_SPEED * 0.05) * 0.5 + 0.5
		n2 = mnoise(nx * 2.5, nz * 2.5, 10) * 0.5 + 0.5
		v = n1 * 0.7 + n2 * 0.3
		if v < CLOUD_COVERAGE then return 0 end
		return mclamp((v - CLOUD_COVERAGE) * INV_CLOUD_RANGE, 0, 1) * CLOUD_OPACITY
	end

	function getSkyRGB(opx, opy, opz, dx, dy, dz, t)
		sun = mmax(0, dx*LDX + dy*LDY + dz*LDZ)
		r = 0
		g = 0
		b = 0
		if sun > 0.995 then
			r, g, b = SUNX, SUNY, SUNZ
		else
			tv = 0.5 * (dy + 1)
			mt = 1 - tv
			r = STPX*tv + SBTX*mt
			g = STPY*tv + SBTY*mt
			b = STPZ*tv + SBTZ*mt
			if sun > 0.98 then
				sf = (sun - 0.98) / 0.015
				r = r + (SUNX - r) * sf
				g = g + (SUNY - g) * sf
				b = b + (SUNZ - b) * sf
			end
		end
		if dy > 0 then
			dist = (CLOUD_HEIGHT - opy) / dy
			if dist > 0 then
				density = getCloudDensity(opx + dx*dist, opz + dz*dist, t)
				if density > 0 then
					f = 1 - sun
					r = r + (CCX + (180 - CCX)*f - r) * density
					g = g + (CCY + (180 - CCY)*f - g) * density
					b = b + (CCZ + (190 - CCZ)*f - b) * density
				end
			end
		end
		if LDY > 0 and sun > 0.65 then
			proximity = (sun - 0.65) / 0.35
			shaftNoise = mnoise(dx * 7 + t * 0.04, dy * 7, dz * 5) * 0.5 + 0.5
			phase = (1 + sun * sun) * 0.75
			strength = proximity * mmax(0, shaftNoise - 0.3) * phase * GOD_RAY_SKY_SHAFTS
			r = r + SUNX * strength
			g = g + SUNY * strength
			b = b + SUNZ * strength
		end
		return r, g, b
	end

	neonBuf = table.create(MAX_NEON_LIGHTS * 2)

	function getNearbyNeon(hpx, hpy, hpz)
		count = 0
		for _, nl in ipairs(neonLights) do
			dx = nl.px - hpx
			dy = nl.py - hpy
			dz = nl.pz - hpz
			dsq = dx*dx + dy*dy + dz*dz
			if dsq < nl.rangeSq then
				count += 1
				neonBuf[count] = { nl = nl, dsq = dsq }
				if count >= MAX_NEON_LIGHTS * 2 then break end
			end
		end
		table.sort(neonBuf, function(a, b) return a.dsq < b.dsq end)
		out = {}
		for i = 1, mmin(count, MAX_NEON_LIGHTS) do out[i] = neonBuf[i] end
		return out
	end

	function CastRayIgnoreTransparent(origin, dirUnit, maxDist)
		curOrigin = origin
		distLeft = maxDist
		attempts = 0
		while attempts < 4 do
			result = Workspace:Raycast(curOrigin, dirUnit * distLeft, params)
			if result then
				inst = result.Instance
				if inst.Transparency > 0.95 or inst.Name == "HumanoidRootPart" then
					traveled = (result.Position - curOrigin).Magnitude
					distLeft -= traveled
					if distLeft <= 0 then return nil end
					curOrigin = result.Position + (dirUnit * 0.01)
					attempts += 1
				else
					return result
				end
			else
				return nil
			end
		end
		return nil
	end

	function getVolumetricGodRay(opx, opy, opz, rdx, rdy, rdz, hitDist)
		cosTheta = rdx*LDX + rdy*LDY + rdz*LDZ
		phase = 1 + mmax(0, cosTheta) * 0.6
		litSamples = 0
		inv = 1 / GOD_RAY_STEPS
		for i = 1, GOD_RAY_STEPS do
			frac = (i - 0.5) * inv
			sx = opx + rdx * frac * hitDist
			sy = opy + rdy * frac * hitDist
			sz = opz + rdz * frac * hitDist
			if not CastRayIgnoreTransparent(Vector3.new(sx, sy, sz), LIGHT_DIR, 100) then
				litSamples += 1 - frac * 0.5
			end
		end
		strength = (litSamples * inv) * GOD_RAY_SCATTER * phase
		return SUNX * strength, SUNY * strength, SUNZ * strength
	end

